# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# Database connection. SQLite is the default (no server needed).
# For MySQL use something like: mysql+pymysql://root:YOUR_PASSWORD@localhost/reading_db
DATABASE_URL=sqlite:///./dev.db

# Google AI Studio — get your own key at https://aistudio.google.com
# DO NOT paste a real key here; put it only in your local .env.
GOOGLE_API_KEY=

# Gemini model selection (override without code changes)
GEMINI_MODEL=gemini-2.5-flash
